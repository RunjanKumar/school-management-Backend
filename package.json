{
  "name": "admin-boilerplate",
  "version": "1.0.0",
  "description": "Node.js + TypeScript + Express",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prepare": "husky install",
    "lint:fix": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,md}' && eslint --fix 'src/**/*.{ts,tsx}' && git add ."
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-healthcheck": "^0.1.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.4.0",
    "handlebars": "^4.7.8",
    "joi": "^17.13.3",
    "joi-to-swagger": "^6.2.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.9.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.1.0",
    "nodemailer": "^6.9.16",
    "prettier": "^3.5.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
