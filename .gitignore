# Ignore node_modules
node_modules/

# Ignore logs
logs/
*.log
npm-debug.log*

# Ignore environment variables
.env
.env.*
!.env.example

# Ignore private credentials
secrets/
firebase-service-account.json
*.service-account.json
*serviceAccount*.json

# Ignore build files
dist/
build/

# Ignore dependency directories
bower_components/

# Ignore IDE specific files
.vscode/
.idea/

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore coverage reports
coverage/

# Ignore temporary files
*.tmp
*.swp

# Ignore upload file
uploads/
public/userFiles/

package-lock.json
swagger.json

# Microservices - ignore built output in all packages/services
packages/*/dist/
services/*/dist/
services/*/logs/
